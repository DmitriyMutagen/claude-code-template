          "metric": "Полный trace от HTTP до БД",
          "xp": 600
        },
        {
          "month": 6,
          "title": "Scale Design",
          "tasks": [
            "Chaos engineering: убить Redis, убить БД, задокументировать результат",
            "Написать runbook для каждого сценария падения"
          ],
          "metric": "RTO < 5 мин для любого сервиса",
          "xp": 1000
        }
      ]
